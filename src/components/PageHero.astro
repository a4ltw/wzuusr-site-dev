---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}
const { title, subtitle, image = '/images/hero.jpg' } = Astro.props;
---
<section class="relative h-56 md:h-72 flex items-center justify-center text-center overflow-hidden">
  <img src={image} alt={title} class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-black/55"></div>
  <div class="relative z-10 px-4">
    <h1 class="text-white text-3xl md:text-5xl font-bold tracking-wide">{title}</h1>
    {subtitle && <p class="text-gray-200 mt-2 text-base md:text-lg">{subtitle}</p>}
  </div>
</section>
