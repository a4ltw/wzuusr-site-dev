---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---
<BaseLayout title="最新活動 — 文藻小螺絲釘 WUTH">
  <PageHero title="最新活動" subtitle="Latest Activities" />
  <div class="max-w-4xl mx-auto px-4 py-16 text-center">
    <p class="text-gray-500 mb-6">活動部落格整合中，請前往活動部落格查看完整活動記錄。</p>
    <a href="/blog" class="inline-block px-8 py-3 bg-[#1a56a0] text-white font-semibold rounded-full hover:bg-blue-800 transition-colors">
      前往活動部落格
    </a>
  </div>
</BaseLayout>
