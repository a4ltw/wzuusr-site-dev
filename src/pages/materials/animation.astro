---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const works = [
  { num: 1, title: '大海裡的家', desc: '一個關於海洋生物與環境保護的溫馨故事，引導孩子認識海洋生態。', url: 'https://reurl.cc/rYd6ME', available: true },
  { num: 2, title: '寄居蟹的時尚災難', desc: '透過寄居蟹尋找新家的故事，讓孩子了解海洋塑膠污染問題。', url: 'https://reurl.cc/RknyAz', available: true },
  { num: 3, title: '海洋小衛士', desc: '鼓勵孩子成為保護海洋的小英雄，從日常生活做起。', url: '', available: false },
  { num: 4, title: '珊瑚的彩色夢', desc: '介紹珊瑚礁生態與氣候變遷的關係，喚起環保意識。', url: '', available: false },
  { num: 5, title: '烏魚的旅程', desc: '結合蚵寮在地文化，述說烏魚洄游的故事。', url: '', available: false },
];
---
<BaseLayout title="動畫／繪本 — 文藻小螺絲釘 WUTH">
  <PageHero title="動畫／繪本" subtitle="Animation & Picture Books" />
  <div class="max-w-4xl mx-auto px-4 py-16">

    <p class="text-center text-gray-500 mb-12">
      文藻 USR 團隊師生共同創作的雙語繪本動畫，結合環保議題與語言學習，適合親子共讀與教學使用。
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {works.map(w => (
        <div class={`bg-white border rounded-2xl p-6 shadow-sm ${w.available ? 'border-gray-100 hover:shadow-md transition-shadow' : 'border-dashed border-gray-200 opacity-70'}`}>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#1a56a0] text-white flex items-center justify-center text-sm font-bold shrink-0">
              {w.num}
            </div>
            <div>
              <h3 class="font-bold text-gray-800 mb-1">{w.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed mb-3">{w.desc}</p>
              {w.available ? (
                <a href={w.url} target="_blank" rel="noopener"
                  class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-red-500 hover:bg-red-600 text-white text-xs font-semibold rounded-full transition-colors">
                  ▶ 觀看影片
                </a>
              ) : (
                <span class="inline-block px-4 py-1.5 bg-gray-100 text-gray-400 text-xs rounded-full">影片連結待更新</span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
